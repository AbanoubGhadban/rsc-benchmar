{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/javascript/src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["app/javascript/**/*.ts", "app/javascript/**/*.tsx"],
  "exclude": ["node_modules"]
}
