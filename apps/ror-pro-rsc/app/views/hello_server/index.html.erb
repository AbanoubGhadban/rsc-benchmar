<style>
  :root {
    color-scheme: light;
    --page-bg: #f5efe5;
    --hero-bg: linear-gradient(135deg, #0d3b66 0%, #165a72 48%, #ef8354 100%);
    --panel-bg: rgba(255, 252, 246, 0.94);
    --ink: #112031;
    --muted: #4d5b6a;
    --line: rgba(17, 32, 49, 0.12);
    --shadow: 0 20px 54px rgba(17, 32, 49, 0.14);
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(239, 131, 84, 0.22), transparent 34%),
      radial-gradient(circle at bottom right, rgba(13, 59, 102, 0.16), transparent 28%),
      var(--page-bg);
    color: var(--ink);
    font-family: "Avenir Next", Avenir, "Segoe UI", sans-serif;
  }

  .ror-demo-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 32px 20px 64px;
  }

  .hero,
  .card,
  .demo-surface {
    border-radius: 28px;
    box-shadow: var(--shadow);
  }

  .hero {
    padding: 32px;
    background: var(--hero-bg);
    color: #fff9f1;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 12px;
    font-weight: 700;
    opacity: 0.8;
  }

  .hero h1 {
    margin: 0;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1;
  }

  .lead {
    max-width: 760px;
    margin: 18px 0 0;
    font-size: 1.04rem;
    line-height: 1.7;
    color: rgba(255, 249, 241, 0.9);
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .link-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 18px;
    border-radius: 999px;
    border: 1px solid rgba(255, 249, 241, 0.24);
    color: inherit;
    text-decoration: none;
    font-weight: 700;
    background: rgba(255, 249, 241, 0.12);
  }

  .demo-surface {
    margin-top: 24px;
    padding: 28px;
    background: var(--panel-bg);
    border: 1px solid var(--line);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
    margin-top: 20px;
  }

  .card {
    padding: 24px;
    background: var(--panel-bg);
    border: 1px solid var(--line);
  }

  .card h2 {
    margin-top: 0;
    margin-bottom: 16px;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
  }

  .card ul {
    margin: 0;
    padding-left: 20px;
  }

  .card li + li {
    margin-top: 12px;
  }

  .card li {
    line-height: 1.65;
    color: var(--muted);
  }

  code {
    padding: 2px 6px;
    border-radius: 8px;
    background: rgba(17, 32, 49, 0.06);
    color: var(--ink);
    font-size: 0.95em;
  }

  @media (max-width: 900px) {
    .hero,
    .card,
    .demo-surface {
      border-radius: 22px;
    }
  }
</style>

<div class="ror-demo-page">
  <section class="hero">
    <p class="eyebrow">React on Rails Pro</p>
    <h1>React Server Components Demo</h1>
    <p class="lead">This route shows the Pro React Server Components flow: Rails streams an async server component response while only client islands ship JavaScript to the browser.</p>

    
      <div class="link-row">
        
          <a href="https://reactonrails.com/docs/pro/react-server-components/" target="_blank" rel="noreferrer">
            Read the RSC guide
          </a>
        
      </div>
    
  </section>

  <section class="demo-surface">
    <%= stream_react_component("HelloServer", props: @hello_server_props) %>
  </section>

  <section class="grid">
    <article class="card">
      <h2>What this page shows</h2>
      <ul>
        
          <li>
            <strong>Async on the server.</strong>
            HelloServer can await data directly during render without pushing that fetch to the client.
          </li>
        
          <li>
            <strong>Small client footprint.</strong>
            Only the interactive LikeButton island needs browser JavaScript.
          </li>
        
          <li>
            <strong>Streaming output.</strong>
            stream_react_component streams HTML as the server component tree resolves.
          </li>
        
      </ul>
    </article>

    <article class="card">
      <h2>Inspect these files next</h2>
      <ul>
        
          <li>
            <code>app/javascript/src/HelloServer/</code><br>
            Source for the generated server component example and client island.
          </li>
        
          <li>
            <code>app/controllers/hello_server_controller.rb</code><br>
            Rails controller that sets props and streams the RSC view.
          </li>
        
          <li>
            <code>app/views/hello_server/index.html.erb</code><br>
            Rails view that calls stream_react_component.
          </li>
        
          <li>
            <code>renderer/node-renderer.js</code><br>
            Node renderer entrypoint used by the Pro SSR and RSC stack.
          </li>
        
      </ul>
    </article>

    <article class="card">
      <h2>Learn more</h2>
      <ul>
        
          <li>
            <a href="https://reactonrails.com/docs/pro/react-server-components/" target="_blank" rel="noreferrer">RSC guide</a>
          </li>
        
          <li>
            <a href="https://reactonrails.com/docs/pro/react-server-components/tutorial/" target="_blank" rel="noreferrer">RSC tutorial</a>
          </li>
        
          <li>
            <a href="https://reactonrails.com/pro/" target="_blank" rel="noreferrer">Pro overview</a>
          </li>
        
          <li>
            <a href="https://github.com/shakacode/react-on-rails-demo-marketplace-rsc" target="_blank" rel="noreferrer">Marketplace RSC demo</a>
          </li>
        
      </ul>
    </article>
  </section>
</div>
