<%= stream_react_component_with_async_props(
  "MegaBenchmark",
  props: { timestamp: Time.now.to_i * 1000 }
) do |emit|
  # Stats query
  stats = {
    user_count: User.count,
    post_count: Post.count,
    comment_count: Comment.count
  }
  emit.call("stats", stats)

  # ALL Users query
  users = User.select(:id, :name, :email).order(:id).map do |u|
    { id: u.id, name: u.name, email: u.email }
  end
  emit.call("users", users)

  # ALL Posts with author query
  posts = Post.joins(:user)
              .select("posts.id, posts.title, posts.body, users.name as author_name")
              .order("posts.id")
              .map do |p|
    { id: p.id, title: p.title, body: p.body, author_name: p.author_name }
  end
  emit.call("posts", posts)

  # ALL Comments with user query
  comments = Comment.joins(:user)
                    .select("comments.id, comments.body, users.name as user_name")
                    .order("comments.id")
                    .map do |c|
    { id: c.id, body: c.body, user_name: c.user_name }
  end
  emit.call("comments", comments)
end %>
